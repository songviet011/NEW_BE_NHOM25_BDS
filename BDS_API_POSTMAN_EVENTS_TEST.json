              "raw": "{\n  \"bat_dong_san_id\": {{bds_id}},\n  \"moi_gioi_id\": {{moi_gioi_id}},\n  \"khach_hang_id\": null,\n  \"gia_giao_dich\": 2500000000,\n  \"mo_ta\": \"Giao dịch test từ Postman\"\n}"
            },
